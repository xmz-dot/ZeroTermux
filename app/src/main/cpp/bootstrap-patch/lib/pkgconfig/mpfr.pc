prefix=/data/data/com.tarmux/files/usr
exec_prefix=${prefix}
libdir=/data/data/com.tarmux/files/usr/lib
includedir=/data/data/com.tarmux/files/usr/include

Name: mpfr
URL: https://www.mpfr.org/
Description: C library for multiple-precision floating-point computations
Version: 4.2.1
Libs: -L${libdir} -lmpfr -lgmp
Cflags: -I${includedir}
