prefix=/data/data/com.tarmux/files/usr
exec_prefix=${prefix}
includedir=/data/data/com.tarmux/files/usr/include
libdir=/data/data/com.tarmux/files/usr/lib
host=aarch64-unknown-linux-android
mtcflags=
mtlibs=-lpthread

Name: gpg-error
Description: GPG Runtime
Version: 1.58-unknown
Cflags: -I${includedir}
Libs: -L${libdir} -lgpg-error
Libs.private: 
