prefix=/data/data/com.tarmux/files/usr
exec_prefix=${prefix}
libdir=/data/data/com.tarmux/files/usr/lib
includedir=/data/data/com.tarmux/files/usr/include

Name: libtirpc
Description: Transport Independent RPC Library
Requires:
Version: 1.3.7
Libs: -L${libdir} -ltirpc
Libs.private: -lpthread
Cflags: -I${includedir}/tirpc
